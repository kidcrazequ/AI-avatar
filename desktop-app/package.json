{
  "name": "soul-desktop",
  "version": "0.5.4",
  "description": "AI分身 - 桌面应用",
  "author": "zhi.qu",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "node build-electron.js && wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "node build-electron.js && vite build",
    "icons": "node scripts/generate-icons.js",
    "pack": "npm run build && npm run icons && electron-builder --dir",
    "dist": "npm run build && npm run icons && electron-builder",
    "dist:mac": "npm run build && npm run icons && electron-builder --mac",
    "dist:win": "npm run build && npm run icons && electron-builder --win",
    "dist:linux": "npm run build && npm run icons && electron-builder --linux",
    "dist:all": "npm run build && npm run icons && electron-builder --mac --win --linux",
    "postinstall": "electron-builder install-app-deps",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "demo:video": "npx playwright test --config=playwright-demo.config.ts",
    "demo:build-and-record": "npm run build && npx playwright test --config=playwright-demo.config.ts",
    "journey:xiaodu": "npx playwright test --config=playwright-journey.config.ts",
    "journey:xiaodu:build": "npm run build && npx playwright test --config=playwright-journey.config.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint src/ electron/ --max-warnings 0",
    "lint:fix": "eslint src/ electron/ --fix",
    "quality": "echo '=== TypeScript 类型检查 ===' && npm run typecheck && echo '=== ESLint 代码质量检查 ===' && npm run lint && echo '=== 全部检查通过 ==='",
    "retrofit:skills": "tsx ../scripts/retrofit-skills.ts"
  },
  "keywords": [
    "electron",
    "desktop",
    "ai",
    "soul"
  ],
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@soul/core": "file:../packages/core",
    "@tailwindcss/postcss": "^4.2.2",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.27",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "eventsource-parser": "^3.0.6",
    "mammoth": "^1.12.0",
    "node-7z": "^3.0.0",
    "node-unrar-js": "^2.0.2",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.4",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "tar": "^7.4.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/node-7z": "^2.1.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/tar": "^6.1.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.27.4",
    "esbuild-plugin-copy": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  }
}
