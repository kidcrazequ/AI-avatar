{
  "name": "soul-desktop",
  "version": "0.15.0",
  "description": "AI分身 - 桌面应用",
  "author": "zhi.qu",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:fresh": "npm run clean:vite && npm run dev",
    "clean:vite": "node -e \"require('fs').rmSync('node_modules/.vite', { recursive: true, force: true })\"",
    "dev:vite": "vite",
    "dev:electron": "node build-electron.js && wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "node build-electron.js && vite build",
    "icons": "node scripts/generate-icons.js",
    "pack": "npm run build && npm run icons && electron-builder --dir",
    "dist": "npm run build && npm run icons && electron-builder",
    "dist:mac": "npm run build && npm run icons && electron-builder --mac && npx @electron/rebuild -f -w better-sqlite3",
    "dist:win": "npm run build && npm run icons && electron-builder --win && npx @electron/rebuild -f -w better-sqlite3",
    "dist:linux": "npm run build && npm run icons && electron-builder --linux && npx @electron/rebuild -f -w better-sqlite3",
    "dist:all": "npm run build && npm run icons && electron-builder --mac --win --linux && npx @electron/rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "test": "npm run test:qa-gate",
    "test:ui": "npm run test:qa-gate",
    "demo:video": "npm run test:qa-gate",
    "demo:build-and-record": "npm run test:qa-gate",
    "journey:xiaodu": "npm run test:qa-gate",
    "journey:xiaodu:build": "npm run test:qa-gate",
    "typecheck": "npx --yes tsc --noEmit",
    "lint": "eslint src/ electron/ --max-warnings 0",
    "lint:fix": "eslint src/ electron/ --fix",
    "quality": "echo '=== TypeScript 类型检查 ===' && npm run typecheck && echo '=== ESLint 代码质量检查 ===' && npm run lint && echo '=== 全部检查通过 ==='",
    "retrofit:skills": "tsx ../scripts/retrofit-skills.ts",
    "backfill:life": "tsx ../scripts/backfill-life.ts",
    "knowledge:inspect": "tsx scripts/knowledge-inspect.ts",
    "test:simulation": "NODE_PATH=./test-support/node_modules npx --yes tsx --test src/services/source-anchor-resolver.test.ts src/services/message-source-annotations.test.ts src/services/message-source-hydration.test.ts src/services/source-reference-actions.test.ts src/services/source-reference-preview.test.ts src/services/reference-simulation.test.ts",
    "test:source-smoke": "NODE_PATH=./test-support/node_modules npx --yes tsx scripts/source-reference-smoke.ts",
    "test:conversation-smoke": "NODE_PATH=./test-support/node_modules npx --yes tsx scripts/conversation-route-smoke.ts",
    "test:manual-qa-scenarios": "NODE_PATH=./test-support/node_modules npx --yes tsx --test src/services/manual-qa-scenarios.test.ts",
    "test:manual-qa-smoke": "NODE_PATH=./test-support/node_modules npx --yes tsx scripts/manual-qa-scenarios-smoke.ts",
    "test:qa-gate": "npm run test:simulation && npm run test:source-smoke && npm run test:conversation-smoke",
    "smoke:static": "npx --yes tsx electron/__smoke__/static-smoke.ts",
    "smoke:verifier:build": "npx esbuild electron/__smoke__/verifier-main.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist-electron/__smoke__/verifier-main.js --external:electron --external:better-sqlite3",
    "smoke:verifier": "npm run smoke:verifier:build && npx electron dist-electron/__smoke__/verifier-main.js",
    "smoke": "npm run smoke:static && npm run smoke:verifier"
  },
  "keywords": [
    "electron",
    "desktop",
    "ai",
    "soul"
  ],
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@antv/infographic": "^0.2.17",
    "@monaco-editor/react": "^4.7.0",
    "@octokit/rest": "^22.0.1",
    "@soul/core": "file:../packages/core",
    "@tailwindcss/postcss": "^4.2.2",
    "7zip-bin": "^5.2.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.27",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "croner": "^10.0.1",
    "cronstrue": "^3.14.0",
    "docx": "^9.6.1",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "eventsource-parser": "^3.0.6",
    "image-size": "^1.2.1",
    "jsdom": "^29.1.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "node-7z": "^3.0.0",
    "node-unrar-js": "^2.0.2",
    "nodejieba": "^3.5.8",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.8",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.4",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "tar": "^7.4.3",
    "turndown": "^7.2.0",
    "webdav": "^5.10.0",
    "word-extractor": "^1.0.4",
    "ws": "^8.20.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^6.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/node-7z": "^2.1.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/tar": "^6.1.13",
    "@types/turndown": "^5.0.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.27.4",
    "esbuild-plugin-copy": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  }
}
