{
  "name": "@soul/core",
  "version": "1.0.0",
  "description": "Soul 分身框架核心 SDK，与运行环境无关（Node.js / Electron / CLI）",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/tests/core.test.js",
    "test:cleaner": "node --test dist/tests/ocr-html-cleaner.test.js",
    "test:all": "node --test dist/tests/core.test.js dist/tests/ocr-html-cleaner.test.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "quality": "echo '=== TypeScript 类型检查 ===' && npm run typecheck && echo '=== ESLint 代码质量检查 ===' && npm run lint && echo '=== 全部检查通过 ==='"
  },
  "keywords": [
    "soul",
    "avatar",
    "ai"
  ],
  "author": "zhi.qu",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "segmentit": "^2.0.3"
  }
}
